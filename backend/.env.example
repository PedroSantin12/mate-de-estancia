PORT=3000
NODE_ENV=development

# Opção 1: PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loja_gaucha
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_SSL=false

# Opção 2: Supabase ou outro PostgreSQL online.
# Ao usar DATABASE_URL, ela substitui os campos DB_HOST, DB_PORT, DB_NAME, DB_USER e DB_PASSWORD.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# DB_SSL=true

# Basic Auth das rotas administrativas obrigatórias
ADMIN_USER=admin
ADMIN_PASSWORD=troque_esta_senha
JWT_SECRET=troque_por_um_segredo_longo
